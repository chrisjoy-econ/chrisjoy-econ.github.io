  <div class="cv-section">
    <h3>Languages</h3>
    <ul class="cv-skills">
      <li>English (native)</li>
      <li>Vietnamese</li>
      <li>Indonesian</li>
      <li>Thai</li>
    </ul>

    <h3 style="margin-top: 1.25rem;">Research Tools</h3>
    <ul class="cv-skills">
      <li>Stata</li>
      <li>R</li>
      <li>SQL</li>
      <li>Python</li>
    </ul>
